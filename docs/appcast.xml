<?xml version="1.0" encoding="utf-8"?>
<!--
  appcast.xml — the Sparkle update feed for Airlive Bridge.  TEMPLATE / reference.

  This is what SUFeedURL (project.yml) points at.  Host the LIVE copy at a
  permanent HTTPS URL you control forever (baked into every shipped build — it
  can NEVER change).  The .dmg itself is served by GitHub Releases (the enclosure
  url); only this tiny XML lives on the feed host.

  Per release: add one <item>.  Its `length` + `sparkle:edSignature` come from
  `sign_update` on the FINAL notarized+stapled .dmg (package.sh prints them), OR
  let `generate_appcast` write the whole file from a folder of signed .dmgs.
  Keep in lockstep: appcast enclosure url  ==  the uploaded GitHub asset name
  ==  the versioned filename package.sh produces (Airlive-Bridge-<version>.dmg).
-->
<rss version="2.0"
     xmlns:sparkle="http://www.andymatuschak.org/xml-namespaces/sparkle"
     xmlns:dc="http://purl.org/dc/elements/1.1/">
  <channel>
    <title>Airlive Bridge</title>
    <link>https://airlive.studio/bridge/appcast.xml</link>
    <description>Most recent updates to Airlive Bridge</description>
    <language>en</language>

    <item>
      <title>Airlive Bridge 1.0.1</title>
      <pubDate>Sun, 05 Jul 2026 12:00:00 +0000</pubDate>
      <!-- sparkle:version = CFBundleVersion (CURRENT_PROJECT_VERSION) — the integer
           Sparkle COMPARES.  shortVersionString = MARKETING_VERSION (display only). -->
      <sparkle:version>2</sparkle:version>
      <sparkle:shortVersionString>1.0.1</sparkle:shortVersionString>
      <sparkle:minimumSystemVersion>13.0</sparkle:minimumSystemVersion>
      <description><![CDATA[
        <h3>What's new in 1.0.1</h3>
        <ul><li>Example release note.</li></ul>
      ]]></description>
      <enclosure
        url="https://github.com/airlive-studio/airlive-bridge/releases/download/v1.0.1/Airlive-Bridge-1.0.1.dmg"
        length="LENGTH_FROM_sign_update"
        type="application/octet-stream"
        sparkle:edSignature="ED_SIGNATURE_FROM_sign_update" />
    </item>

  </channel>
</rss>
